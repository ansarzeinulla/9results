  });

  it("does not refresh on a short pull", () => {
    const { container } = render(
      <PullToRefresh>
        <p>content</p>
      </PullToRefresh>,
    );
    pull(container.firstChild as HTMLElement, 40);
    expect(refresh).not.toHaveBeenCalled();
  });
});
