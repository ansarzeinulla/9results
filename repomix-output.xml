def test_anon_can_call_omni_search(migrated_db):
    with psycopg.connect(migrated_db) as db:
        db.execute("SET ROLE anon")
        rows = db.execute("SELECT * FROM omni_search(%s, 8)", ("Омни",)).fetchall()
