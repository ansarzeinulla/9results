    with psycopg.connect(migrated_db) as db:
        pids = [r[0] for r in db.execute(
            "SELECT id FROM pairings WHERE round_id=%s", (rid,)).fetchall()]
    client.post(f"/api/rounds/{rid}/results", headers=auth(org), json={
