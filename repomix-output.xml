        assert cyr_player in fuzzy(db, "Нұрланова")
        assert cyr_player in fuzzy(db, "Нурланова")  # russian spelling, no ұ


def test_typo_still_finds_the_player(cyr_player, migrated_db):
    with psycopg.connect(migrated_db) as db:
