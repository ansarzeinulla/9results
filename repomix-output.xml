          </h1>
          <div className="text-sm text-neutral-500">
            ID: {player.id} · {player.federation_id}
            {player.year_of_birth ? ` · ${player.year_of_birth}` : ""}
            {player.club ? ` · ${player.club}` : ""}
          </div>
        </div>
