{
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "npm install && npm install --prefix backend",
  "framework": null,
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "backend/src/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/index.html"
    }
  ],
  "functions": {
    "backend/src/index.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 60
    }
  }
}
